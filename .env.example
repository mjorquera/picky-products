# Picky Products — Environment Variables
# Copy this to .env and fill in your values. Never commit .env.

# Anthropic (used by Cowork)
ANTHROPIC_API_KEY=""

# Pinterest API v5
# Get these by running: python3 pinterest_auth.py
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
PINTEREST_ACCESS_TOKEN=""
PINTEREST_REFRESH_TOKEN=""
PINTEREST_BOARD_ID=""

# Notion internal integration
# Create at: https://www.notion.so/my-integrations
# Then share the Distribution DB with the integration inside Notion
NOTION_TOKEN=""
