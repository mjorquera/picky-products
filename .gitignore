pins/*/product.jpg
pins/*/product.png

# Generated PNGs (reproducible from product.jpg + hooks.json)
pins/*/*.png

# Notion export artefacts
*.csv

# Claude Code local settings (may contain tokens)
.claude/

# Editor
.vscode/
.idea/
*.swp
